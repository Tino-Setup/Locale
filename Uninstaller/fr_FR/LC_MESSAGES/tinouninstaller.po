#: Pages.py:17
msgid "Welcome to the {} Uninstaller"
msgstr "Bienvenue dans le désinstallateur de {}"

#: Pages.py:19
msgid ""
"This uninstaller will guide you through the removal of\n"
"{} and its data from your computer.\n"
"\n"
"Click Uninstall to continue or Cancel to abort the uninstallation."
msgstr ""
"Ce désinstallateur vous guidera tout au long de la suppression de\n"
"{} et de ses données de votre ordinateur.\n"
"\n"
"Cliquez sur Désinstaller pour continuer ou sur Annuler pour interrompre la "
"désinstallation."

#: Pages.py:30
msgid "Uninstalling {}..."
msgstr "Désinstallation de {}..."

#: Pages.py:37
msgid "Preparing..."
msgstr "Préparation..."

#: Wizard.py:50
msgid "Yes"
msgstr "Oui"

#: Wizard.py:52
msgid "No"
msgstr "Non"

#: Wizard.py:55
msgid "OK"
msgstr "OK"

#: Wizard.py:94
msgid "{} Uninstaller"
msgstr "Désinstallateur de {}"

#: Wizard.py:111
msgid "{} by {}"
msgstr "{} par {}"

#: Wizard.py:114 Wizard.py:178
msgid "Next"
msgstr "Suivant"

#: Wizard.py:116
msgid "Cancel"
msgstr "Annuler"

#: Wizard.py:190
msgid "Finish"
msgstr "Terminer"

#: Wizard.py:192
msgid "Uninstall"
msgstr "Désinstaller"

#: Wizard.py:198
msgid "Uninstallation Failed"
msgstr "Échec de la désinstallation"

#: Wizard.py:200
msgid ""
"An error occurred during the uninstallation of {}.\n"
"\n"
"Some files may have already been removed.\n"
"Click Finish to close the uninstaller."
msgstr ""
"Une erreur s'est produite lors de la désinstallation de {}.\n"
"\n"
"Certains fichiers peuvent avoir déjà été supprimés.\n"
"Cliquez sur Terminer pour fermer le désinstallateur."

#: Wizard.py:205
msgid "Uninstallation Complete"
msgstr "Désinstallation terminée"

#: Wizard.py:207
msgid ""
"{} has been successfully uninstalled.\n"
"\n"
"Click Finish to close the uninstaller."
msgstr ""
"{} a été désinstallé avec succès.\n"
"\n"
"Cliquez sur Terminer pour fermer le désinstallateur."

#: Wizard.py:225
msgid "Confirm Uninstallation"
msgstr "Confirmer la désinstallation"

#: Wizard.py:226
msgid ""
"Are you sure you want to uninstall {}?\n"
"\n"
"All files and data associated with this application will be removed."
msgstr ""
"Êtes-vous sûr de vouloir désinstaller {} ?\n"
"\n"
"Tous les fichiers et données associés à cette application seront supprimés."

#: Wizard.py:239
msgid "Starting uninstallation..."
msgstr "Démarrage de la désinstallation..."

#: Wizard.py:246
msgid "Script file not found: {}"
msgstr "Fichier de script introuvable : {}"

#: Wizard.py:263
msgid "Script returned non-zero exit code {}"
msgstr "Le script a renvoyé un code de sortie non nul {}"

#: Wizard.py:280
msgid "Running pre-uninstallation script..."
msgstr "Exécution du script de pré-désinstallation..."

#: Wizard.py:286
msgid "Removing executable..."
msgstr "Suppression de l'exécutable..."

#: Wizard.py:294
msgid "Removing icon..."
msgstr "Suppression de l'icône..."

#: Wizard.py:302
msgid "Removing desktop shortcut..."
msgstr "Suppression du raccourci bureau..."

#: Wizard.py:310
msgid "Removing uninstaller desktop shortcut..."
msgstr "Suppression du raccourci bureau du désinstallateur..."

#: Wizard.py:318
msgid "Removing uninstaller icon..."
msgstr "Suppression de l'icône du programme de désinstallation..."

#: Wizard.py:326
msgid "Removing installation directory..."
msgstr "Suppression du répertoire d'installation..."

#: Wizard.py:333
msgid "Removing uninstaller executable..."
msgstr "Suppression de l'exécutable de désinstallation..."

#: Wizard.py:346
msgid "Running post-uninstallation script..."
msgstr "Exécution du script de post-désinstallation..."

#: Wizard.py:365
msgid ""
"Script execution failed during uninstallation.\n"
"\n"
"The uninstallation has been aborted.\n"
"\n"
"Details:\n"
"{}"
msgstr ""
"L'exécution du script a échoué pendant la désinstallation.\n"
"\n"
"La désinstallation a été annulée.\n"
"\n"
"Détails :\n"
"{}"

#: Wizard.py:374
msgid "Uninstallation complete!"
msgstr "Désinstallation terminée !"

#: Wizard.py:387
msgid ""
"Permission denied during uninstallation.\n"
"\n"
"Some files may have already been removed.\n"
"\n"
"Details:\n"
"{}"
msgstr ""
"Permission refusée pendant la désinstallation.\n"
"\n"
"Certains fichiers peuvent avoir déjà été supprimés.\n"
"\n"
"Détails :\n"
"{}"

#: Wizard.py:390
msgid "Uninstallation Error"
msgstr "Erreur de désinstallation"

#: Wizard.py:396
msgid "Uninstallation in Progress"
msgstr "Désinstallation en cours"

#: Wizard.py:397
msgid "The uninstallation process has started and cannot be cancelled."
msgstr "Le processus de désinstallation a commencé et ne peut pas être annulé."
